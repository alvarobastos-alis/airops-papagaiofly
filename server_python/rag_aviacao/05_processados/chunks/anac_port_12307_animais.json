    ],
    "article": "Art. 8",
    "flight_scope": [
      "domestico",
      "internacional"
    ],
    "business_scope": [
      "passageiro"
    ],
    "effective_from": "2023-07-01",
    "effective_to": null,
    "version": "original",
    "text": "Art. 8º Animais braquicefálicos (focinho curto) têm restrições adicionais:\nI - proibido o transporte no porão em temperaturas acima de 30°C;\nII - recomenda-se preferência pelo transporte em cabine quando possível.\n\nCAPÍTULO IV - VOOS INTERNACIONAIS",
    "char_count": 248,
    "split_method": "article_boundary",
    "chunk_index": 8,
    "total_chunks": 10
  },
  {
    "chunk_id": "anac_port_12307_animais_chunk_0009_13b2998f",
