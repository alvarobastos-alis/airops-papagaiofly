    "effective_to": null,
    "version": "original",
    "text": "PORTARIA ANAC Nº 12.307, DE 30 DE JUNHO DE 2023\n\nDispõe sobre o transporte de animais em aeronaves civis.",
    "char_count": 105,
    "split_method": "article_boundary",
    "chunk_index": 0,
    "total_chunks": 10
  },
  {
    "chunk_id": "anac_port_12307_animais_chunk_0001_2b431e6b",
    "document_id": "anac_port_12307_animais",
