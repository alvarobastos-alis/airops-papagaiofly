    ],
    "article": "Art. 7",
    "flight_scope": [
      "domestico",
      "internacional"
    ],
    "business_scope": [
      "passageiro"
    ],
    "effective_from": "2023-07-01",
    "effective_to": null,
    "version": "original",
    "text": "Art. 7º O transporte de animais como carga viva no porão climatizado está sujeito a:\nI - caixa de transporte certificada pela IATA;\nII - atestado veterinário com validade de até 10 dias;\nIII - reserva prévia junto à empresa aérea;\nIV - pagamento de tarifa específica.",
    "char_count": 267,
    "split_method": "article_boundary",
    "chunk_index": 7,
    "total_chunks": 10
  },
  {
    "chunk_id": "anac_port_12307_animais_chunk_0008_62d2b8b7",
    "document_id": "anac_port_12307_animais",
    "document_name": "Portaria ANAC nº 12.307/2023",
    "source_type": "norma_publica",
